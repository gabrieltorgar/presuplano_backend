# === Django ===
DEBUG=True
SECRET_KEY=change-me-in-production
ALLOWED_HOSTS=localhost,127.0.0.1
CORS_ALLOWED_ORIGINS=http://localhost:5173

# === Database ===
# Local dev/test default is SQLite; production uses Neon Postgres:
# DATABASE_URL=postgres://user:pass@host:5432/dbname
DATABASE_URL=sqlite:///db.sqlite3

# === Logging ===
LOG_DIR=tmp/logs

# === OTP (universal code for the MVP; real SMS/WhatsApp integration later) ===
OTP_UNIVERSAL_CODE=123456
OTP_TTL_MINUTES=10

# === Media storage — Cloudflare R2 (S3-compatible) ===
# Media (progress evidence images) persists in R2 in production. Leave blank to
# use the local filesystem in dev/tests. R2 turns on automatically when the four
# core values are present (or force it with USE_R2=True).
# USE_R2=True
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=
# Optional: defaults to https://<account_id>.r2.cloudflarestorage.com
R2_ENDPOINT_URL=
# Public host that serves the objects (r2.dev subdomain or your custom domain)
R2_PUBLIC_URL=
